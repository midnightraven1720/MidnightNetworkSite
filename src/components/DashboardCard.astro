---
const { title } = Astro.props;
---
<div class="card">
  <h3>{title}</h3>
  <slot />
</div>

<style>
  .card { background: #1A1430; padding: 1rem; border-radius: 8px; border: 1px solid #2A2145; }
  .card h3 { font-size: 1.15rem; color: #C4B5FD; margin: 0 0 0.5rem; }
  .card :global(p) { margin: 0; }
  .card :global(.placeholder-note) {
    font-size: 0.9rem;
    color: #8A7FA8;
    line-height: 1.5;
  }
</style>
