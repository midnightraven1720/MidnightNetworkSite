---
const { apps, applicationsAvailable, selectedGuildId } = Astro.props;
---
<div class="panel">
  <h3>Applications <span class="count">{apps.length}</span></h3>
  {applicationsAvailable ? (
    apps.length > 0 ? (
      <ul class="detail-list">
        {apps.map((a) => (
          <li>
            <span class="detail-primary">{a.username}</span>
            <span class="detail-secondary">{selectedGuildId === 'all' && `${a.guildName} · `}status: {a.status}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="placeholder-note">No applications awaiting review.</p>
    )
  ) : (
    <p class="placeholder-note">Couldn't reach the bot right now.</p>
  )}
</div>

<style>
  .panel { background: #1A1430; border: 1px solid #2A2145; border-radius: 12px; padding: 1.5rem; }
  .panel h3 { margin: 0 0 1rem; font-size: 1.1rem; color: #C4B5FD; display: flex; align-items: center; gap: 0.5rem; }
  .count { font-size: 0.8rem; background: #2A2145; color: #F0EDF7; border-radius: 999px; padding: 0.1rem 0.6rem; }
  .detail-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .detail-list li { display: flex; flex-direction: column; gap: 0.15rem; padding-bottom: 0.75rem; border-bottom: 1px solid #2A2145; }
  .detail-list li:last-child { border-bottom: none; padding-bottom: 0; }
  .detail-primary { color: #F0EDF7; font-weight: 600; font-size: 0.95rem; }
  .detail-secondary { color: #8A7FA8; font-size: 0.8rem; }
  .placeholder-note { margin: 0; font-size: 0.9rem; color: #8A7FA8; line-height: 1.5; }
</style>
