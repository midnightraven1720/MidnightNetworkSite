---
import { servers } from '../../data/servers.js';
---
<div id="view-servers" style="display: none;">
  <h3>Server Listing</h3>
  <ul class="detail-list">
    {servers.map((s) => (
      <li>
        <span class="detail-primary">{s.name}</span>
        <a class="detail-secondary" href={`/servers/${s.slug}`}>/servers/{s.slug}</a>
        {s.partner && <span class="status-text active process">PARTNER</span>}
      </li>
    ))}
  </ul>
</div>

<style>
  .status-text { font-size: 0.45rem; color: #5A5270; background: #1A1430; padding: 1px 4px; border: 1px solid #2A2145; border-radius: 3px; text-transform: uppercase; font-weight: bold; }
  .status-text.active.process { color: #22D3EE; border-color: #22D3EE; }
  .detail-list { list-style: none; margin: 0.75rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .detail-list li { display: flex; align-items: center; gap: 0.6rem; padding-bottom: 0.5rem; border-bottom: 1px solid #2A2145; }
  .detail-list li:last-child { border-bottom: none; padding-bottom: 0; }
  .detail-primary { color: #F0EDF7; font-weight: 600; font-size: 0.8rem; }
  .detail-secondary { color: #8A5CF6; font-size: 0.7rem; text-decoration: none; }
  .detail-secondary:hover { color: #C4B5FD; }
</style>
