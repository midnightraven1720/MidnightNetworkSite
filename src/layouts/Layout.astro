---
const { title } = Astro.props;
const path = Astro.url.pathname;

const isActive = (href) => {
  if (href === '/') return path === '/';
  return path.startsWith(href);
};

const sessionCookie = Astro.cookies.get('midnight_session');
let user = null;
if (sessionCookie) {
  try {
    user = JSON.parse(sessionCookie.value);
  } catch {
    user = null;
  }
}
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Midnight Network</title>
  </head>
  <body>
    <input type="checkbox" id="nav-toggle" class="nav-toggle-checkbox" />
    <nav class="tabs">
      <a href="/" class="site-title">Midnight Network</a>

      <label for="nav-toggle" class="hamburger-btn" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </label>

      <div class="nav-menu">
        <div class="tab-links">
          <a href="/" class={`tab ${isActive('/') ? 'active' : ''}`}>Home</a>
          <a href="/servers" class={`tab ${isActive('/servers') ? 'active' : ''}`}>Servers</a>
          <a href="/bots" class={`tab ${isActive('/bots') ? 'active' : ''}`}>Bots</a>
          <a href="/partnerships" class={`tab ${isActive('/partnerships') ? 'active' : ''}`}>Partnerships</a>
          <a href="/about-us" class={`tab ${isActive('/about-us') ? 'active' : ''}`}>About Us</a>
        </div>
        <div class="auth-area">
          {user ? (
            <div class="user-badge">
              {user.avatar && (
                <img
                  src={`https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=32`}
                  alt={user.username}
                  class="user-avatar"
                />
              )}
              <a href={user.rank === 'member' ? '/user-dashboard' : '/staff-dashboard'} class="username">{user.username}</a>
              <a href="/logout" class="logout-link">Log out</a>
            </div>
          ) : (
            <a href="/login" class="login-button">Login with Discord</a>
          )}
        </div>
      </div>
    </nav>
    <slot />
    <footer>
      <p>&copy; Midnight Network</p>
      <div class="footer-links">
        <a href="/terms-of-use">Terms of Use</a>
        <span class="footer-dot">•</span>
        <a href="/privacy-policy">Privacy Policy</a>
      </div>
    </footer>
  </body>
</html>
<style is:global>
  body {
    margin: 0;
    background-color: #0F0B1E;
    color: #F0EDF7;
    font-family: system-ui, sans-serif;
  }
  .nav-toggle-checkbox {
    display: none;
  }
  .tabs {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.5rem;
    background-color: #150F26;
    border-bottom: 1px solid #2A2145;
    position: sticky;
    top: 0;
    z-index: 20;
    gap: 1rem;
    flex-wrap: nowrap;
  }
  .site-title {
    color: #F0EDF7;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .site-title:hover {
    color: #C4B5FD;
  }

  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .hamburger-btn span {
    display: block;
    height: 2px;
    width: 100%;
    background-color: #F0EDF7;
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: flex-end;
    min-width: 0;
  }
  .tab-links {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
    min-width: 0;
  }
  .tab {
    color: #F0EDF7;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.45rem 0.7rem;
    border-radius: 6px;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;
  }
  .tab:hover {
    background-color: #8A5CF6;
  }
  .tab.active {
    background-color: #8A5CF6;
    color: #F0EDF7;
    font-weight: 600;
  }
  .auth-area {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .login-button {
    display: inline-block;
    padding: 0.45rem 1rem;
    background-color: #5865F2;
    color: #FFFFFF;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    white-space: nowrap;
    transition: background-color 0.2s;
  }
  .login-button:hover {
    background-color: #4752C4;
  }
  .user-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .user-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
  }
  .username {
    font-size: 0.85rem;
    font-weight: 600;
    color: #C4B5FD;
    white-space: nowrap;
    text-decoration: none;
  }
  .logout-link {
    color: #8A7FA8;
    text-decoration: none;
    font-size: 0.8rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    transition: background-color 0.2s;
  }
  .logout-link:hover {
    background-color: #2A2145;
    color: #F0EDF7;
  }
  footer {
    text-align: center;
    padding: 2rem;
    color: #8A7FA8;
    font-size: 0.9rem;
  }
  .footer-links {
    margin-top: 0.5rem;
  }
  .footer-links a {
    color: #8A7FA8;
    text-decoration: none;
  }
  .footer-links a:hover {
    color: #C4B5FD;
  }
  .footer-dot {
    margin: 0 0.5rem;
    color: #8A7FA8;
  }
  .section {
    padding: 4rem 2rem;
    text-align: center;
  }
  .section h2 {
    font-size: 2rem;
    color: #C4B5FD;
  }

  /* ===== Mobile nav ===== */
  @media (max-width: 768px) {
    .hamburger-btn {
      display: flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: #150F26;
      border-bottom: 1px solid #2A2145;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .tab-links {
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0;
    }
    .tab {
      padding: 0.9rem 1.5rem;
      border-radius: 0;
    }
    .auth-area {
      padding: 0.75rem 1.5rem 1rem;
      border-top: 1px solid #2A2145;
    }
    .login-button {
      width: 100%;
      text-align: center;
    }
    .user-badge {
      justify-content: space-between;
      width: 100%;
    }

    .nav-toggle-checkbox:checked ~ .tabs .nav-menu {
      max-height: 500px;
    }
  }
</style>