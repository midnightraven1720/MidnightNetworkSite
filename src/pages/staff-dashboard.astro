---
import Layout from '../layouts/Layout.astro';

const sessionCookie = Astro.cookies.get('midnight_session');
let user = null;
if (sessionCookie) {
  try {
    user = JSON.parse(sessionCookie.value);
  } catch {
    user = null;
  }
}

if (!user) {
  return Astro.redirect('/login');
}
---
<Layout title="Staff Dashboard">
  <section class="section">
    <h2>Staff Dashboard</h2>
    <p class="intro-note">Note: this isn't restricted to staff yet — that check gets added once we connect it to your bots.</p>
  </section>

  <section class="section">
    <div class="card-grid">
      <div class="card">
        <h3>Tickets &amp; Applications</h3>
        <p class="placeholder-note">Coming soon — open tickets and pending staff applications, pulled from Midnight Tickets.</p>
      </div>

      <div class="card">
        <h3>Suggestions Queue</h3>
        <p class="placeholder-note">Coming soon — suggestions awaiting a staff decision, from the Midnight Network bot.</p>
      </div>

      <div class="card">
        <h3>Bot Health</h3>
        <p class="placeholder-note">Coming soon — online/offline status for all 12 network bots.</p>
      </div>

      <div class="card">
        <h3>Moderation &amp; Blacklist</h3>
        <p class="placeholder-note">Coming soon — recent warnings, notes, and blacklist entries from Midnight Council.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <a href="/account" class="staff-link">&larr; Back to My Dashboard</a>
  </section>
</Layout>
<style>
  .intro-note {
    max-width: 600px;
    margin: 0.5rem auto 0;
    color: #8A7FA8;
    font-size: 0.9rem;
  }
  h3 {
    font-size: 1.15rem;
    color: #C4B5FD;
    margin: 0 0 0.5rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  .card {
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: left;
  }
  .placeholder-note {
    margin: 0;
    font-size: 0.9rem;
    color: #8A7FA8;
    line-height: 1.5;
  }
  .staff-link {
    color: #8A5CF6;
    font-weight: 600;
    text-decoration: none;
  }
  .staff-link:hover {
    color: #C4B5FD;
  }
</style>