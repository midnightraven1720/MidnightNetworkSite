---
import Layout from '../layouts/Layout.astro';

const sessionCookie = Astro.cookies.get('midnight_session');
let user = null;
if (sessionCookie) {
  try {
    user = JSON.parse(sessionCookie.value);
  } catch {
    user = null;
  }
}

if (!user) {
  return Astro.redirect('/login');
}

const API_BASE = 'http://midnight-tickets.railway.internal:3001';
const API_KEY = import.meta.env.DASHBOARD_API_KEY;

async function fetchFromBot(path) {
  try {
    const res = await fetch(`${API_BASE}${path}`, {
      headers: { 'x-api-key': API_KEY },
    });
    if (!res.ok) return null;
    return await res.json();
  } catch {
    return null;
  }
}

const serversData = await fetchFromBot('/api/servers');
const ticketsData = await fetchFromBot('/api/tickets');
const applicationsData = await fetchFromBot('/api/applications');
const healthData = await fetchFromBot('/api/health');

const botOnline = healthData !== null;
const servers = serversData ? serversData.servers : [];
const useDropdown = servers.length >= 8;

const selectedGuildId = Astro.url.searchParams.get('server') || 'all';

const allTickets = ticketsData ? ticketsData.tickets : [];
const allApplications = applicationsData ? applicationsData.applications : [];

const filteredTickets = selectedGuildId === 'all'
  ? allTickets
  : allTickets.filter(t => t.guildId === selectedGuildId);

const filteredApplications = selectedGuildId === 'all'
  ? allApplications
  : allApplications.filter(a => a.guildId === selectedGuildId);
---
<Layout title="Staff Dashboard">
  <section class="section">
    <h2>Staff Dashboard</h2>
    <p class="intro-note">Note: this isn't restricted to staff yet — that check gets added once we connect it to your bots.</p>
  </section>

  <div class="top-tabs">
    <input type="radio" name="topTab" id="top-servers" class="tab-radio" checked />
    <input type="radio" name="topTab" id="top-bots" class="tab-radio" />

    <div class="top-tab-buttons">
      <label for="top-servers" class="top-tab-btn">Servers</label>
      <label for="top-bots" class="top-tab-btn">Bots</label>
    </div>

    <div class="top-panel panel-servers">
      <div class="dashboard-layout">
        <aside class="server-nav">
          {useDropdown ? (
            <form method="get" class="server-dropdown-form">
              <select name="server" class="server-dropdown" onchange="this.form.submit()">
                <option value="all" selected={selectedGuildId === 'all'}>All Servers</option>
                {servers.map((s) => (
                  <option value={s.id} selected={selectedGuildId === s.id}>{s.name}</option>
                ))}
              </select>
            </form>
          ) : (
            <ul class="server-list">
              <li>
                <a href="/staff-dashboard?server=all" class={selectedGuildId === 'all' ? 'active' : ''}>All Servers</a>
              </li>
              {servers.map((s) => (
                <li>
                  <a href={`/staff-dashboard?server=${s.id}`} class={selectedGuildId === s.id ? 'active' : ''}>{s.name}</a>
                </li>
              ))}
            </ul>
          )}
        </aside>

        <div class="dashboard-content">
          <div class="cat-tabs">
            <input type="radio" name="catTab" id="cat-tickets" class="tab-radio" checked />
            <input type="radio" name="catTab" id="cat-applications" class="tab-radio" />
            <input type="radio" name="catTab" id="cat-moderation" class="tab-radio" />

            <div class="cat-tab-buttons">
              <label for="cat-tickets" class="cat-tab-btn">
                <span class="cat-name">Tickets</span>
                <span class="cat-count">{ticketsData ? filteredTickets.length : '—'}</span>
              </label>
              <label for="cat-applications" class="cat-tab-btn">
                <span class="cat-name">Applications</span>
                <span class="cat-count">{applicationsData ? filteredApplications.length : '—'}</span>
              </label>
              <label for="cat-moderation" class="cat-tab-btn">
                <span class="cat-name">Moderation &amp; Blacklist</span>
                <span class="cat-count">—</span>
              </label>
            </div>

            <div class="cat-panel panel-tickets">
              {ticketsData ? (
                filteredTickets.length > 0 ? (
                  <ul class="detail-list">
                    {filteredTickets.map((t) => (
                      <li>
                        <span class="detail-primary">{t.username}</span>
                        <span class="detail-secondary">{t.typeKey} {selectedGuildId === 'all' && `· ${t.guildName}`} · opened {new Date(t.openedAt).toLocaleDateString()}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="placeholder-note">No open tickets right now.</p>
                )
              ) : (
                <p class="placeholder-note">Couldn't reach the bot right now.</p>
              )}
            </div>

            <div class="cat-panel panel-applications">
              {applicationsData ? (
                filteredApplications.length > 0 ? (
                  <ul class="detail-list">
                    {filteredApplications.map((a) => (
                      <li>
                        <span class="detail-primary">{a.username}</span>
                        <span class="detail-secondary">{selectedGuildId === 'all' && `${a.guildName} · `}status: {a.status}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="placeholder-note">No applications awaiting review.</p>
                )
              ) : (
                <p class="placeholder-note">Couldn't reach the bot right now.</p>
              )}
            </div>

            <div class="cat-panel panel-moderation">
              <p class="placeholder-note">Coming soon — recent warnings, notes, and blacklist entries from Midnight Council.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="top-panel panel-bots">
      <div class="bot-status-list">
        <div class="bot-status-card">
          <div class="bot-status-header">
            <h3>Midnight Tickets</h3>
            <span class={`status-line ${botOnline ? 'status-online' : 'status-offline'}`}>
              {botOnline ? '● Online' : '● Offline / Unreachable'}
            </span>
          </div>
          {healthData ? (
            <>
              <p class="stat-label">Uptime: {Math.floor(healthData.uptimeSeconds / 60)} minutes</p>
              {healthData.recentErrors.length > 0 ? (
                <ul class="mini-list error-list">
                  {healthData.recentErrors.slice(0, 8).map((e) => (
                    <li>{e.message} <span class="error-time">({new Date(e.timestamp).toLocaleString()})</span></li>
                  ))}
                </ul>
              ) : (
                <p class="placeholder-note">No recent errors logged.</p>
              )}
            </>
          ) : (
            <p class="placeholder-note">Couldn't reach this bot right now.</p>
          )}
        </div>

        <div class="bot-status-card">
          <div class="bot-status-header">
            <h3>Other Bots</h3>
            <span class="status-line status-planned">— Not built yet</span>
          </div>
          <p class="placeholder-note">Health monitoring for the rest of the network's bots will appear here once they're built and connected.</p>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <a href="/account" class="staff-link">&larr; Back to My Dashboard</a>
  </section>
</Layout>
<style>
  .intro-note {
    max-width: 600px;
    margin: 0.5rem auto 0;
    color: #8A7FA8;
    font-size: 0.9rem;
  }

  .tab-radio {
    display: none;
  }

  /* Top-level tabs: Servers / Bots */
  .top-tab-buttons {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin: 1.5rem auto;
    max-width: 1200px;
    padding: 0 1.5rem;
  }
  .top-tab-btn {
    cursor: pointer;
    padding: 0.6rem 1.5rem;
    border-radius: 8px;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    color: #B8AED0;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background-color 0.2s, color 0.2s;
  }
  .top-tab-btn:hover {
    color: #F0EDF7;
  }
  .top-panel {
    display: none;
  }
  #top-servers:checked ~ .panel-servers {
    display: block;
  }
  #top-bots:checked ~ .panel-bots {
    display: block;
  }
  #top-servers:checked ~ .top-tab-buttons label[for="top-servers"],
  #top-bots:checked ~ .top-tab-buttons label[for="top-bots"] {
    background-color: #8A5CF6;
    color: #F0EDF7;
  }

  /* Servers layout */
  .dashboard-layout {
    display: flex;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    align-items: flex-start;
  }
  .server-nav {
    flex-shrink: 0;
    width: 200px;
  }
  .server-dropdown-form {
    width: 100%;
  }
  .server-dropdown {
    width: 100%;
    padding: 0.6rem;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 8px;
    color: #F0EDF7;
    font-size: 0.9rem;
  }
  .server-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .server-list a {
    display: block;
    padding: 0.6rem 0.9rem;
    border-radius: 8px;
    color: #B8AED0;
    text-decoration: none;
    font-size: 0.9rem;
    transition: background-color 0.2s, color 0.2s;
  }
  .server-list a:hover {
    background-color: #1A1430;
    color: #F0EDF7;
  }
  .server-list a.active {
    background-color: #8A5CF6;
    color: #F0EDF7;
    font-weight: 600;
  }
  .dashboard-content {
    flex: 1;
    min-width: 0;
  }

  /* Category tabs: Tickets / Applications / Moderation */
  .cat-tab-buttons {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .cat-tab-btn {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.85rem 1.25rem;
    border-radius: 10px;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    min-width: 140px;
    transition: border-color 0.2s;
  }
  .cat-tab-btn:hover {
    border-color: #8A5CF6;
  }
  .cat-name {
    font-size: 0.8rem;
    color: #B8AED0;
    font-weight: 600;
  }
  .cat-count {
    font-size: 1.5rem;
    font-weight: 700;
    color: #F0EDF7;
  }
  .cat-panel {
    display: none;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1.5rem;
  }
  #cat-tickets:checked ~ .cat-tab-buttons label[for="cat-tickets"],
  #cat-applications:checked ~ .cat-tab-buttons label[for="cat-applications"],
  #cat-moderation:checked ~ .cat-tab-buttons label[for="cat-moderation"] {
    border-color: #8A5CF6;
    background-color: #241B3D;
  }
  #cat-tickets:checked ~ .panel-tickets {
    display: block;
  }
  #cat-applications:checked ~ .panel-applications {
    display: block;
  }
  #cat-moderation:checked ~ .panel-moderation {
    display: block;
  }

  .detail-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .detail-list li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #2A2145;
  }
  .detail-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .detail-primary {
    color: #F0EDF7;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .detail-secondary {
    color: #8A7FA8;
    font-size: 0.8rem;
  }

  /* Bots tab */
  .bot-status-list {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .bot-status-card {
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: left;
  }
  .bot-status-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .bot-status-header h3 {
    font-size: 1.1rem;
    color: #C4B5FD;
    margin: 0;
  }
  .status-line {
    font-weight: 600;
    font-size: 0.85rem;
  }
  .status-online {
    color: #22C55E;
  }
  .status-offline {
    color: #EF4444;
  }
  .status-planned {
    color: #8A7FA8;
  }
  .mini-list {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
    color: #F0EDF7;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .error-list li {
    color: #F0A5A5;
  }
  .error-time {
    color: #8A7FA8;
    font-size: 0.75rem;
  }
  .stat-label {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    color: #8A7FA8;
  }
  .placeholder-note {
    margin: 0;
    font-size: 0.9rem;
    color: #8A7FA8;
    line-height: 1.5;
  }

  .staff-link {
    display: block;
    color: #8A5CF6;
    font-weight: 600;
    text-decoration: none;
  }
  .staff-link:hover {
    color: #C4B5FD;
  }

  @media (max-width: 640px) {
    .dashboard-layout {
      flex-direction: column;
    }
    .server-nav {
      width: 100%;
    }
  }
</style>