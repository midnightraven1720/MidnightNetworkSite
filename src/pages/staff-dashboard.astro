---
// src/pages/staff-dashboard.astro
import Layout from '../layouts/Layout.astro';
import BackButton from '../components/BackButton.astro';
import TicketsPanel from '../components/staff/TicketsPanel.astro';
import ApplicationsPanel from '../components/staff/ApplicationsPanel.astro';
import ServerRolesPanel from '../components/staff/ServerRolesPanel.astro';
import { requireStaff } from '../lib/session.js';
import { getStaffData } from '../lib/staff-logic.js';

const { redirect } = requireStaff(Astro);
if (redirect) return redirect;

const selectedGuildId = Astro.url.searchParams.get('server') || 'all';
const data = await getStaffData(selectedGuildId);

const selectedServer = data.servers.find((s) => s.id === selectedGuildId);
const guildName = selectedGuildId === 'all' ? 'All Servers' : (selectedServer?.name || 'Selected Server');
---

<Layout title="Staff Dashboard">
  <div class="dashboard-wrapper">
    <aside class="server-nav">
      <nav class="back-nav">
        <BackButton href="/user-dashboard" label="← User Dashboard" />
      </nav>

      <ul class="server-list">
        <li><a href="/staff-dashboard?server=all" class={selectedGuildId === 'all' ? 'active' : ''}>All Servers</a></li>
        {data.servers.map((s) => (
          <li><a href={`/staff-dashboard?server=${s.id}`} class={selectedGuildId === s.id ? 'active' : ''}>{s.name}</a></li>
        ))}
      </ul>
    </aside>

    <main class="content">
      <h1>Dashboard for {guildName}</h1>

      <div class="panel-grid">
        <TicketsPanel tickets={data.filteredTickets} ticketsAvailable={data.ticketsAvailable} selectedGuildId={selectedGuildId} />
        <ApplicationsPanel apps={data.filteredApps} applicationsAvailable={data.applicationsAvailable} selectedGuildId={selectedGuildId} />
        {selectedGuildId !== 'all' && data.guildOptionsData && (
          <ServerRolesPanel guildOptionsData={data.guildOptionsData} />
        )}
      </div>

      <div class="page-footer">
        <BackButton href="/user-dashboard" label="← User Dashboard" />
      </div>
    </main>
  </div>
</Layout>

<style>
  .dashboard-wrapper {
    display: flex;
  }
  .server-nav {
    width: 250px;
    flex-shrink: 0;
    background: #0F0B1E;
    border-right: 1px solid #2A2145;
    align-self: flex-start;
    position: sticky;
    top: 0;
    max-height: 100vh;
    overflow-y: auto;
  }
  .back-nav {
    padding: 1rem;
    border-bottom: 1px solid #2A2145;
  }
  .server-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .server-list li a {
    display: block;
    padding: 1rem;
    color: #B8AED0;
    text-decoration: none;
  }
  .server-list li a.active {
    background: #2A2145;
    color: white;
  }
  .content {
    padding: 2rem;
    flex: 1;
    min-width: 0;
  }
  .panel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .page-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #2A2145;
  }
</style>
