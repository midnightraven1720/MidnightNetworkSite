---
import Layout from '../layouts/Layout.astro';

const sessionCookie = Astro.cookies.get('midnight_session');
let user = null;
if (sessionCookie) {
  try {
    user = JSON.parse(sessionCookie.value);
  } catch {
    user = null;
  }
}

if (!user) {
  return Astro.redirect('/login');
}

const API_BASE = 'http://midnight-tickets.railway.internal:3001';
const API_KEY = import.meta.env.DASHBOARD_API_KEY;

async function fetchFromBot(path) {
  try {
    const res = await fetch(`${API_BASE}${path}`, {
      headers: { 'x-api-key': API_KEY },
    });
    if (!res.ok) return null;
    return await res.json();
  } catch {
    return null;
  }
}

const serversData = await fetchFromBot('/api/servers');
const ticketsData = await fetchFromBot('/api/tickets');
const applicationsData = await fetchFromBot('/api/applications');
const healthData = await fetchFromBot('/api/health');
const botConfigData = await fetchFromBot('/api/bot-config');

const departments = [
  {
    name: "Leadership",
    members: [
      { name: "Staff Member", role: "Owner" },
      { name: "Staff Member", role: "Co-Owner" },
    ]
  },
  {
    name: "Moderation",
    members: [
      { name: "Staff Member", role: "Admin" },
      { name: "Staff Member", role: "Mod" },
      { name: "Staff Member", role: "Helper" },
    ]
  },
  {
    name: "Partnerships",
    members: [
      { name: "Staff Member", role: "Partnership Manager" },
    ]
  },
  {
    name: "Events",
    members: [
      { name: "Staff Member", role: "Event Manager" },
    ]
  },
  {
    name: "Health Department",
    members: [
      { name: "Staff Member", role: "Health Department" },
    ]
  },
];

const botOnline = healthData !== null;
const servers = serversData ? serversData.servers : [];
const useDropdown = servers.length >= 8;

const selectedGuildId = Astro.url.searchParams.get('server') || 'all';

const allTickets = ticketsData ? ticketsData.tickets : [];
const allApplications = applicationsData ? applicationsData.applications : [];

const filteredTickets = selectedGuildId === 'all'
  ? allTickets
  : allTickets.filter(t => t.guildId === selectedGuildId);

const filteredApplications = selectedGuildId === 'all'
  ? allApplications
  : allApplications.filter(a => a.guildId === selectedGuildId);

const allConfigs = botConfigData ? botConfigData.configs : [];
const selectedConfig = selectedGuildId === 'all'
  ? null
  : allConfigs.find(c => c.guildId === selectedGuildId);

function serverLink(guildId) {
  return `/staff-dashboard?server=${guildId}`;
}
---
<Layout title="Staff Dashboard">
  <section class="section">
    <h2>Staff Dashboard</h2>
    <p class="intro-note">Note: this isn't restricted to staff yet — that check gets added once we connect it to your bots.</p>
  </section>

  <div class="main-tabs">
    <input type="radio" name="mainTab" id="main-staff" class="tab-radio" checked />
    <input type="radio" name="mainTab" id="main-bot" class="tab-radio" />

    <div class="main-tab-buttons">
      <label for="main-staff" class="main-tab-btn">Staff Dashboard</label>
      <label for="main-bot" class="main-tab-btn">Bot Dashboard</label>
    </div>

    <!-- ============ STAFF DASHBOARD TAB ============ -->
    <div class="main-panel panel-main-staff">
      <div class="dashboard-layout">
        <aside class="server-nav">
          {useDropdown ? (
            <form method="get" class="server-dropdown-form">
              <select name="server" class="server-dropdown" onchange="this.form.submit()">
                <option value="all" selected={selectedGuildId === 'all'}>All Servers</option>
                {servers.map((s) => (
                  <option value={s.id} selected={selectedGuildId === s.id}>{s.name}</option>
                ))}
              </select>
            </form>
          ) : (
            <ul class="server-list">
              <li><a href="/staff-dashboard?server=all" class={selectedGuildId === 'all' ? 'active' : ''}>All Servers</a></li>
              {servers.map((s) => (
                <li><a href={serverLink(s.id)} class={selectedGuildId === s.id ? 'active' : ''}>{s.name}</a></li>
              ))}
            </ul>
          )}
        </aside>

        <div class="dashboard-content">
          <div class="staff-bio-card">
            <h3>Staff Directory</h3>
            <p class="placeholder-note-small">Network-wide directory below. Per-server bios/ranks are coming once Midnight Council is live.</p>
            <div class="department-grid">
              {departments.map(dept => (
                <div class="department-mini">
                  <h4>{dept.name}</h4>
                  <ul class="mini-list">
                    {dept.members.map(m => <li>{m.name} — {m.role}</li>)}
                  </ul>
                </div>
              ))}
            </div>
          </div>

          <div class="cat-tabs">
            <input type="radio" name="catTab" id="cat-tickets" class="tab-radio" checked />
            <input type="radio" name="catTab" id="cat-applications" class="tab-radio" />
            <input type="radio" name="catTab" id="cat-moderation" class="tab-radio" />

            <div class="cat-tab-buttons">
              <label for="cat-tickets" class="cat-tab-btn">
                <span class="cat-name">Tickets</span>
                <span class="cat-count">{ticketsData ? filteredTickets.length : '—'}</span>
              </label>
              <label for="cat-applications" class="cat-tab-btn">
                <span class="cat-name">Applications</span>
                <span class="cat-count">{applicationsData ? filteredApplications.length : '—'}</span>
              </label>
              <label for="cat-moderation" class="cat-tab-btn">
                <span class="cat-name">Moderation &amp; Blacklist</span>
                <span class="cat-count">—</span>
              </label>
            </div>

            <div class="cat-panel panel-tickets">
              {ticketsData ? (
                filteredTickets.length > 0 ? (
                  <ul class="detail-list">
                    {filteredTickets.map((t) => (
                      <li>
                        <span class="detail-primary">{t.username}</span>
                        <span class="detail-secondary">{t.typeKey} {selectedGuildId === 'all' && `· ${t.guildName}`} · opened {new Date(t.openedAt).toLocaleDateString()}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="placeholder-note">No open tickets right now.</p>
                )
              ) : (
                <p class="placeholder-note">Couldn't reach the bot right now.</p>
              )}
            </div>

            <div class="cat-panel panel-applications">
              {applicationsData ? (
                filteredApplications.length > 0 ? (
                  <ul class="detail-list">
                    {filteredApplications.map((a) => (
                      <li>
                        <span class="detail-primary">{a.username}</span>
                        <span class="detail-secondary">{selectedGuildId === 'all' && `${a.guildName} · `}status: {a.status}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="placeholder-note">No applications awaiting review.</p>
                )
              ) : (
                <p class="placeholder-note">Couldn't reach the bot right now.</p>
              )}
            </div>

            <div class="cat-panel panel-moderation">
              <p class="placeholder-note">Coming soon — searchable warning history, notes, and blacklist entries for every member, once Midnight Council is live.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ============ BOT DASHBOARD TAB ============ -->
    <div class="main-panel panel-main-bot">
      <div class="dashboard-layout">
        <aside class="server-nav">
          {useDropdown ? (
            <form method="get" class="server-dropdown-form">
              <select name="server" class="server-dropdown" onchange="this.form.submit()">
                <option value="all" selected={selectedGuildId === 'all'}>All Servers</option>
                {servers.map((s) => (
                  <option value={s.id} selected={selectedGuildId === s.id}>{s.name}</option>
                ))}
              </select>
            </form>
          ) : (
            <ul class="server-list">
              <li><a href="/staff-dashboard?server=all" class={selectedGuildId === 'all' ? 'active' : ''}>All Servers</a></li>
              {servers.map((s) => (
                <li><a href={serverLink(s.id)} class={selectedGuildId === s.id ? 'active' : ''}>{s.name}</a></li>
              ))}
            </ul>
          )}
        </aside>

        <div class="dashboard-content">
          <div class="bot-config-card">
            <h3>Midnight Tickets — Configuration</h3>
            {selectedGuildId === 'all' ? (
              <p class="placeholder-note">Select a specific server from the list to view its bot configuration.</p>
            ) : botConfigData && selectedConfig ? (
              <div class="config-grid">
                <div>
                  <h4>Roles</h4>
                  <ul class="config-list">
                    <li><span class="config-key">Ticket Staff:</span> {selectedConfig.roles.ticketStaff ? selectedConfig.roles.ticketStaff.name : 'Not set'}</li>
                    <li><span class="config-key">Owner:</span> {selectedConfig.roles.owner ? selectedConfig.roles.owner.name : 'Not set'}</li>
                    <li><span class="config-key">Co-Owner:</span> {selectedConfig.roles.coOwner ? selectedConfig.roles.coOwner.name : 'Not set'}</li>
                    <li><span class="config-key">Partnership Manager:</span> {selectedConfig.roles.partnershipManager ? selectedConfig.roles.partnershipManager.name : 'Not set'}</li>
                    <li><span class="config-key">ID Verified Staff:</span> {selectedConfig.roles.idVerifiedStaff ? selectedConfig.roles.idVerifiedStaff.name : 'Not set'}</li>
                  </ul>
                </div>
                <div>
                  <h4>Categories</h4>
                  <ul class="config-list">
                    <li><span class="config-key">Support/Report/Partnership:</span> {selectedConfig.categories.support ? selectedConfig.categories.support.name : 'Not set'}</li>
                    <li><span class="config-key">Staff Reports:</span> {selectedConfig.categories.staffReport ? selectedConfig.categories.staffReport.name : 'Not set'}</li>
                    <li><span class="config-key">Verification:</span> {selectedConfig.categories.verification ? selectedConfig.categories.verification.name : 'Not set'}</li>
                  </ul>
                </div>
              </div>
            ) : (
              <p class="placeholder-note">Couldn't reach the bot right now.</p>
            )}
            <p class="edit-note">This view is read-only for now — editing these values directly from the dashboard is planned for later.</p>
          </div>

          <div class="bot-status-list">
            <div class="bot-status-card">
              <div class="bot-status-header">
                <h3>Midnight Tickets</h3>
                <span class={`status-line ${botOnline ? 'status-online' : 'status-offline'}`}>
                  {botOnline ? '● Online' : '● Offline / Unreachable'}
                </span>
              </div>
              {healthData ? (
                <>
                  <p class="stat-label">Uptime: {Math.floor(healthData.uptimeSeconds / 60)} minutes</p>
                  {healthData.recentErrors.length > 0 ? (
                    <ul class="mini-list error-list">
                      {healthData.recentErrors.slice(0, 8).map((e) => (
                        <li>{e.message} <span class="error-time">({new Date(e.timestamp).toLocaleString()})</span></li>
                      ))}
                    </ul>
                  ) : (
                    <p class="placeholder-note">No recent errors logged.</p>
                  )}
                </>
              ) : (
                <p class="placeholder-note">Couldn't reach this bot right now.</p>
              )}
            </div>

            <div class="bot-status-card">
              <div class="bot-status-header">
                <h3>Other Bots</h3>
                <span class="status-line status-planned">— Not built yet</span>
              </div>
              <p class="placeholder-note">Health monitoring for the rest of the network's bots will appear here once they're built and connected.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <a href="/account" class="staff-link">&larr; Back to My Dashboard</a>
  </section>
</Layout>
<style>
  .intro-note {
    max-width: 600px;
    margin: 0.5rem auto 0;
    color: #8A7FA8;
    font-size: 0.9rem;
  }
  .tab-radio {
    display: none;
  }

  .main-tab-buttons {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin: 1.5rem auto;
    max-width: 1200px;
    padding: 0 1.5rem;
  }
  .main-tab-btn {
    cursor: pointer;
    padding: 0.6rem 1.5rem;
    border-radius: 8px;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    color: #B8AED0;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background-color 0.2s, color 0.2s;
  }
  .main-tab-btn:hover {
    color: #F0EDF7;
  }
  .main-panel {
    display: none;
  }
  #main-staff:checked ~ .panel-main-staff {
    display: block;
  }
  #main-bot:checked ~ .panel-main-bot {
    display: block;
  }
  #main-staff:checked ~ .main-tab-buttons label[for="main-staff"],
  #main-bot:checked ~ .main-tab-buttons label[for="main-bot"] {
    background-color: #8A5CF6;
    color: #F0EDF7;
  }

  .dashboard-layout {
    display: flex;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
    align-items: flex-start;
  }
  .server-nav {
    flex-shrink: 0;
    width: 200px;
  }
  .server-dropdown-form {
    width: 100%;
  }
  .server-dropdown {
    width: 100%;
    padding: 0.6rem;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 8px;
    color: #F0EDF7;
    font-size: 0.9rem;
  }
  .server-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .server-list a {
    display: block;
    padding: 0.6rem 0.9rem;
    border-radius: 8px;
    color: #B8AED0;
    text-decoration: none;
    font-size: 0.9rem;
    transition: background-color 0.2s, color 0.2s;
  }
  .server-list a:hover {
    background-color: #1A1430;
    color: #F0EDF7;
  }
  .server-list a.active {
    background-color: #8A5CF6;
    color: #F0EDF7;
    font-weight: 600;
  }
  .dashboard-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  h3 {
    font-size: 1.1rem;
    color: #C4B5FD;
    margin: 0 0 0.5rem;
  }
  h4 {
    font-size: 0.9rem;
    color: #B8AED0;
    margin: 0 0 0.5rem;
  }

  .staff-bio-card,
  .bot-config-card {
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: left;
  }

  .placeholder-note-small {
    margin: 0 0 1rem;
    font-size: 0.8rem;
    color: #8A7FA8;
  }
  .department-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.25rem;
  }
  .department-mini h4 {
    color: #8A5CF6;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.5rem;
  }

  .config-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .config-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: #F0EDF7;
  }
  .config-key {
    color: #8A7FA8;
  }
  .edit-note {
    margin: 0;
    font-size: 0.75rem;
    color: #8A7FA8;
    font-style: italic;
  }

  .cat-tab-buttons {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .cat-tab-btn {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.85rem 1.25rem;
    border-radius: 10px;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    min-width: 140px;
    transition: border-color 0.2s;
  }
  .cat-tab-btn:hover {
    border-color: #8A5CF6;
  }
  .cat-name {
    font-size: 0.8rem;
    color: #B8AED0;
    font-weight: 600;
  }
  .cat-count {
    font-size: 1.5rem;
    font-weight: 700;
    color: #F0EDF7;
  }
  .cat-panel {
    display: none;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1.5rem;
  }
  #cat-tickets:checked ~ .cat-tab-buttons label[for="cat-tickets"],
  #cat-applications:checked ~ .cat-tab-buttons label[for="cat-applications"],
  #cat-moderation:checked ~ .cat-tab-buttons label[for="cat-moderation"] {
    border-color: #8A5CF6;
    background-color: #241B3D;
  }
  #cat-tickets:checked ~ .panel-tickets {
    display: block;
  }
  #cat-applications:checked ~ .panel-applications {
    display: block;
  }
  #cat-moderation:checked ~ .panel-moderation {
    display: block;
  }

  .detail-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .detail-list li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #2A2145;
  }
  .detail-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .detail-primary {
    color: #F0EDF7;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .detail-secondary {
    color: #8A7FA8;
    font-size: 0.8rem;
  }

  .bot-status-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .bot-status-card {
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: left;
  }
  .bot-status-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .bot-status-header h3 {
    margin: 0;
  }
  .status-line {
    font-weight: 600;
    font-size: 0.85rem;
  }
  .status-online {
    color: #22C55E;
  }
  .status-offline {
    color: #EF4444;
  }
  .status-planned {
    color: #8A7FA8;
  }
  .mini-list {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
    color: #F0EDF7;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .error-list li {
    color: #F0A5A5;
  }
  .error-time {
    color: #8A7FA8;
    font-size: 0.75rem;
  }
  .stat-label {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    color: #8A7FA8;
  }
  .placeholder-note {
    margin: 0;
    font-size: 0.9rem;
    color: #8A7FA8;
    line-height: 1.5;
  }

  .staff-link {
    display: block;
    color: #8A5CF6;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    margin-top: 1rem;
  }
  .staff-link:hover {
    color: #C4B5FD;
  }

  @media (max-width: 640px) {
    .dashboard-layout {
      flex-direction: column;
    }
    .server-nav {
      width: 100%;
    }
  }
</style>