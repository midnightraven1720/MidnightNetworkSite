---
console.log('CALLBACK HIT - code present:', !!Astro.url.searchParams.get('code'));

const code = Astro.url.searchParams.get('code');

if (!code) {
  return Astro.redirect('/login');
}

const siteUrl = import.meta.env.SITE_URL || Astro.url.origin;
const redirectUri = `${siteUrl}/auth/callback`;

const tokenResponse = await fetch('https://discord.com/api/oauth2/token', {
  method: 'POST',
  headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
  body: new URLSearchParams({
    client_id: import.meta.env.DISCORD_CLIENT_ID,
    client_secret: import.meta.env.DISCORD_CLIENT_SECRET,
    grant_type: 'authorization_code',
    code: code,
    redirect_uri: redirectUri,
  }),
});

if (!tokenResponse.ok) {
  const errorBody = await tokenResponse.text();
  console.error('Token exchange failed:', tokenResponse.status, errorBody);
  return Astro.redirect('/login?error=token_exchange_failed');
}

const tokenData = await tokenResponse.json();

const userResponse = await fetch('https://discord.com/api/users/@me', {
  headers: { Authorization: `Bearer ${tokenData.access_token}` },
});

if (!userResponse.ok) {
  const errorBody = await userResponse.text();
  console.error('User fetch failed:', userResponse.status, errorBody);
  return Astro.redirect('/login?error=user_fetch_failed');
}

const discordUser = await userResponse.json();

Astro.cookies.set('midnight_session', JSON.stringify({
  id: discordUser.id,
  username: discordUser.username,
  avatar: discordUser.avatar,
}), {
  path: '/',
  httpOnly: true,
  secure: import.meta.env.PROD,
  sameSite: 'lax',
  maxAge: 60 * 60 * 24 * 7,
});

return Astro.redirect('/account');
---