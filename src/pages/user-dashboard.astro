---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';

const sessionCookie = Astro.cookies.get('midnight_session');
let user = null;
if (sessionCookie) {
  try {
    user = JSON.parse(sessionCookie.value);
  } catch {
    user = null;
  }
}

if (!user) {
  return Astro.redirect('/login');
}

const avatarUrl = user.avatar
  ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=128`
  : null;
---

<Layout title="User Dashboard">
  <div class="dashboard-wrapper">
    <Sidebar />
    <main class="content">
      <div class="header-bar">
        <div class="profile-info">
          {avatarUrl && <img src={avatarUrl} alt={user.username} class="profile-avatar" />}
          <h1>Welcome, {user.username}</h1>
        </div>
        <button class="safeword-btn" onclick="alert('Safeword Triggered!')">SAFEWORD</button>
      </div>

      <div class="card-grid">
        <div class="card"><h3>Active Tickets</h3><p>1 open ticket.</p></div>
        <div class="card"><h3>Current Bonds</h3><p>Bound</p></div>
        <div class="card"><h3>RP Status</h3><p>Active Scene</p></div>
        <div class="card">
          <h3>Level &amp; Currency</h3>
          <p class="placeholder-note">Coming soon — this will show your Server and Network XP, level, and currency wallets once Midnight Ascend is live.</p>
        </div>
        <div class="card">
          <h3>Warnings</h3>
          <p class="placeholder-note">Coming soon — you'll be able to see your own warning count here once Midnight Council is live.</p>
        </div>
        <div class="card">
          <h3>My Profiles</h3>
          <p class="placeholder-note">Coming soon — quick links to your Kink, Gamer, Anime &amp; Manga, and Books profiles once Midnight Profiles is live.</p>
        </div>
        <div class="card">
          <h3>Server Memberships</h3>
          <p class="placeholder-note">Coming soon — a list of which Midnight Network servers you're a member of.</p>
        </div>
      </div>

      {user.rank !== 'member' && (
        <a href="/staff-dashboard" class="staff-link">Staff? View the Staff Dashboard &rarr;</a>
      )}
    </main>
  </div>
</Layout>

<style>
  .dashboard-wrapper { display: flex; min-height: 100vh; background: #0A0714; color: white; }
  .content { padding: 1.5rem; flex: 1; overflow: hidden; }
  .header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .profile-info { display: flex; align-items: center; gap: 1rem; }
  .profile-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid #2A2145;
  }
  .safeword-btn { background: #FF0033; color: white; border: none; padding: 0.4rem 1rem; font-weight: bold; cursor: pointer; border-radius: 4px; text-transform: uppercase; }

  .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; }
  .card { background: #1A1430; padding: 1rem; border-radius: 8px; border: 1px solid #2A2145; }
  .card h3 { font-size: 1.15rem; color: #C4B5FD; margin: 0 0 0.5rem; }
  .placeholder-note {
    margin: 0;
    font-size: 0.9rem;
    color: #8A7FA8;
    line-height: 1.5;
  }
  .staff-link {
    display: block;
    margin-top: 1.5rem;
    color: #8A5CF6;
    font-weight: 600;
    text-decoration: none;
  }
  .staff-link:hover {
    color: #C4B5FD;
  }
</style>