const bannerMap = {
  'midnight-tickets': 'bot-tickets.jpg',
  'midnight-network': 'bots.jpg',
  'midnight-council': 'bot-council.jpg',
  'midnight-ascend': 'bot-ascend.jpg',
  'midnight-roles': 'bot-roles.jpg',
  'midnight-bonds': 'bot-bonds.jpg',
  'midnight-collar': 'bot-collar.jpg',
  'midnight-profiles': 'bot-profiles.jpg',
  'midnight-watch': 'bot-watch.jpg',
  'midnight-blueprint': 'bot-blueprint.jpg',
  'midnight-bot-roleplay': 'bot-roleplay.jpg',
  'midnight-advertising': 'bot-advertising.jpg',
};

const bannerPositionMap = {
  'midnight-collar': 'center 70%',
};

const bot = botData[slug];

if (!bot) {
  return Astro.redirect('/bots');
}

const bannerFile = bannerMap[slug] || 'bots.jpg';
const bannerPosition = bannerPositionMap[slug] || 'center 30%';

// Check staff rank
const sessionCookie = Astro.cookies.get('midnight_session');
let user = null;
if (sessionCookie) {
  try {
    user = JSON.parse(sessionCookie.value);
  } catch {
    user = null;
  }
}
const STAFF_TIERS = ['owner', 'coOwner', 'staff'];
const canEdit = user && STAFF_TIERS.includes(user.rank);

// Fetch staff-written content overrides
const pageContentData = await fetchFromBot('/api/bot-page-content');
const override = pageContentData?.pages?.[slug];
const summary = override?.summary || bot.summary;
const highlights = override?.highlights || bot.highlights;

// Fetch live commands if this bot actually exists
let commands = bot.plannedCommands;
let commandsAreLive = false;
if (bot.hasLiveBot) {
  const liveCommandsData = await fetchFromBot('/api/commands');
  if (liveCommandsData?.commands) {
    commands = liveCommandsData.commands;
    commandsAreLive = true;
  }
}

const saved = Astro.url.searchParams.get('saved') === 'true';
---
<Layout title={bot.name}>
  <div class="page-banner" style={`background-image: url('/banners/${bannerFile}'); background-position: ${bannerPosition};`}>
    <a href="/bots" class="banner-back-link">&larr; Back to Bots</a>
    <h2>{bot.name}</h2>
  </div>

  <section class="section">
    <span class={`badge ${bot.status === 'Live' ? 'badge-live' : 'badge-planned'}`}>{bot.status}</span>
    {saved && <p class="saved-note">✓ Changes saved.</p>}

    <div class="bot-tabs">
      <input type="radio" name="bottab" id="tab-overview" class="tab-radio" checked />
      <input type="radio" name="bottab" id="tab-details" class="tab-radio" />
      <input type="radio" name="bottab" id="tab-commands" class="tab-radio" />

      <div class="tab-buttons">
        <label for="tab-overview" class="tab-btn">Overview</label>
        <label for="tab-details" class="tab-btn">Details</label>
        <label for="tab-commands" class="tab-btn">Commands</label>
      </div>

      <div class="tab-panel panel-overview">
        <p class="summary-text">{summary}</p>
      </div>

      <div class="tab-panel panel-details">
        <ul class="info-list">
          {highlights.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="tab-panel panel-commands">
        {!commandsAreLive && bot.hasLiveBot === false && (
          <p class="planned-note">These commands are planned — this bot isn't built yet.</p>
        )}
        <ul class="command-list">
          {commands.map((cmd) => (
            <li>
              <code class="command-name">{cmd.name}</code>
              <p class="command-desc">{cmd.description}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {canEdit && (
      <details class="edit-section">
        <summary>Edit this page</summary>
        <form method="post" action="/api/save-bot-page">
          <input type="hidden" name="slug" value={slug} />
          <label class="edit-field">
            <span>Summary</span>
            <textarea name="summary" rows="3">{summary}</textarea>
          </label>
          <label class="edit-field">
            <span>Highlights (one per line)</span>
            <textarea name="highlights" rows="6">{highlights.join('\n')}</textarea>
          </label>
          <button type="submit" class="save-btn">Save Changes</button>
        </form>
      </details>
    )}
  </section>

  <section class="section">
    <a href="/bots" class="back-link">&larr; Back to Bots</a>
  </section>
</Layout>
<style>
  .page-banner {
    background-size: cover;
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
