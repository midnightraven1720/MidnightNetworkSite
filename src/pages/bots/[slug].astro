    background-color: rgba(138, 92, 246, 0.8);
  }
  .page-banner h2 {
    font-size: 2.5rem;
    color: #F0EDF7;
    text-shadow: 0 2px 12px rgba(0,0,0,0.8);
    margin: 0;
  }
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  .badge-live {
    background-color: #22C55E;
    color: #08130C;
  }
  .badge-planned {
    background-color: #2A2145;
    color: #B8AED0;
  }
  .saved-note {
    color: #22C55E;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .bot-tabs {
    max-width: 700px;
    margin: 1.5rem auto 0;
    padding: 0 1rem;
    text-align: left;
  }
  .tab-radio {
    display: none;
  }
  .tab-buttons {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .tab-btn {
    cursor: pointer;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    color: #B8AED0;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background-color 0.2s, color 0.2s;
  }
  .tab-btn:hover {
    color: #F0EDF7;
  }
  .tab-panel {
    display: none;
  }
  #tab-overview:checked ~ .panel-overview {
    display: block;
    text-align: center;
  }
  #tab-details:checked ~ .panel-details {
    display: block;
  }
  #tab-commands:checked ~ .panel-commands {
    display: block;
  }
  #tab-overview:checked ~ .tab-buttons label[for="tab-overview"],
  #tab-details:checked ~ .tab-buttons label[for="tab-details"],
  #tab-commands:checked ~ .tab-buttons label[for="tab-commands"] {
    background-color: #8A5CF6;
    color: #F0EDF7;
  }
  .summary-text {
    color: #B8AED0;
    max-width: 500px;
    margin: 0 auto;
  }
  .info-list {
    color: #F0EDF7;
    line-height: 1.8;
    padding-left: 1.5rem;
    margin: 0;
  }
  .planned-note {
    color: #8A7FA8;
    font-size: 0.85rem;
    font-style: italic;
    margin: 0 0 1rem;
  }
  .command-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .command-list li {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #2A2145;
  }
  .command-list li:last-child {
    border-bottom: none;
  }
  .command-name {
    display: inline-block;
    background-color: #1A1430;
    color: #C4B5FD;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
  }
  .command-desc {
    margin: 0;
    color: #B8AED0;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .edit-section {
    max-width: 700px;
    margin: 2rem auto 0;
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1rem 1.5rem;
  }
  .edit-section summary {
    cursor: pointer;
    color: #8A5CF6;
    font-weight: 600;
  }
  .edit-field {
    display: block;
    margin: 1rem 0;
    font-size: 0.85rem;
    color: #B8AED0;
  }
  .edit-field textarea {
    width: 100%;
    margin-top: 0.4rem;
    padding: 0.6rem;
    background-color: #0F0B1E;
    border: 1px solid #2A2145;
    border-radius: 6px;
    color: #F0EDF7;
    font-family: inherit;
    font-size: 0.9rem;
    resize: vertical;
    box-sizing: border-box;
  }
  .save-btn {
    padding: 0.6rem 1.5rem;
    background-color: #8A5CF6;
    color: #F0EDF7;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .save-btn:hover {
    background-color: #7C4FE0;
  }
  .back-link {
    display: block;
    color: #8A5CF6;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    margin-top: 1.5rem;
  }
  .back-link:hover {
    color: #C4B5FD;
  }
</style>