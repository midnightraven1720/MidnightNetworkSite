---
import Layout from '../../layouts/Layout.astro';
import BotTabs from '../../components/BotTabs.astro';

const summary = "Handles the network's ticket system, age verification, and staff applications. Covers general support, user/staff reports, partnership requests, and a full multi-part staff application flow with branching questions based on role track.";

const details = [
  {
    title: "Age Verification",
    description: "Every new member who wants full access to the network's 18+ spaces goes through Midnight Tickets' verification flow. Instead of relying on a simple checkbox or an honor system, staff issue a unique verification word paired with a countdown timer through the /verify-word command. The member has to respond with that exact word within the time limit, which weeds out bots, alt accounts, and people who aren't paying attention. Once a staff member reviews the interaction, they either approve it with /verify-approve, which automatically grants both a base verified role and the appropriate gender tag role, or deny it with /verify-deny if something doesn't check out. Every verification welcome message can be customized per-server, with its own dedicated channel and message template, so each community in the network can introduce newly verified members in a way that fits its own tone and culture. This whole process is designed to be fast for genuine members while still giving staff a real decision point rather than automating trust away entirely."
  },
  {
    title: "General Support Tickets",
    description: "The General Support ticket type is the network's everyday help desk. Any member who has a question, needs a hand navigating a server, or runs into an issue that doesn't fit a more specific category can open one through the ticket panel with a single click. Behind the scenes, the ticket routes to whichever category staff have configured for that server, and the assigned Ticket Staff role gets visibility into it automatically. What makes this more than a plain text channel is the /staff-reply command, which lets staff respond inside the ticket anonymously, showing as a generic staff identity rather than an individual's Discord account. This protects staff privacy while still giving members a responsive, personal-feeling support experience. Tickets stay open until a staff member resolves them, and the whole system is built to scale across all seven Midnight Network servers from one shared codebase, so support quality stays consistent no matter which community someone is asking for help in."
  },
  {
    title: "User & Staff Reports",
    description: "Midnight Tickets separates 'Report a User' and 'Report a Staff Member' into two distinct ticket types, each with its own structured modal so the reporting member doesn't have to guess what information matters. A user report captures who's involved, what happened, and any supporting context right at the point of submission, which saves back-and-forth and gives staff a clean starting point for moderation decisions. Reporting a staff member works the same way but routes differently — these tickets are visible only to higher-tier staff roles like Owners, Co-Owners, and Network Staff, so a report about someone's conduct never ends up in front of the very person it concerns. This separation matters a lot in a large, multi-server community where trust in leadership needs to be protected as carefully as trust in the membership. Every report ticket ties back into the same audit trail that Midnight Watch will eventually track, so patterns of repeated behavior — by members or by staff — become visible over time instead of getting lost across scattered conversations."
  },
  {
    title: "Partnership Requests",
    description: "When another server wants to explore a partnership with the Midnight Network, the Partnership Request ticket type gives them a direct, structured way to reach Network Leadership without needing to know who specifically to DM. The intake modal collects exactly what staff need to make an informed decision — details about the requesting server, what kind of partnership they're looking for, and why they think it's a good fit — mirroring the same information staff would otherwise have to chase down manually. This ticket type is intentionally kept separate from general support and reports because partnership evaluation involves a different group of people and a different decision process entirely; it's routed to whichever Partnership Manager role has been configured, keeping the conversation focused and confidential during the vetting period. Since the whole Partnership Program itself runs on a trial-first model, this ticket is often just the opening move in a longer relationship — the first structured touchpoint before a two-month trial period even begins."
  },
  {
    title: "Staff Application Flow",
    description: "The Staff Application ticket type runs the most involved flow in the entire bot. It starts with 20 general questions that apply to every applicant regardless of what role they're going for, covering things like availability, experience, and general fit for the network's culture. From there, the flow branches based on which track the applicant is pursuing: Server Staff applicants get 15 scenario-based questions focused on moderating a single community, while Network Staff applicants get a separate set of 15 scenario questions focused on network-wide responsibilities and cross-server consistency. Depending on the specific role someone's applying for within their chosen track, up to 2 additional scenario questions get appended at the end, tailored to that position's particular responsibilities. One detail that keeps this system from becoming stale is that the very first question dynamically lists whichever servers the bot is currently active in, so applicants are always working from an accurate, up-to-date picture of the network rather than a hardcoded list that falls out of sync as new servers join or leave."
  },
];

const commands = [
  { command: "/ticket-panel", description: "Posts the ticket button panel that members use to open a new ticket." },
  { command: "/verification-panel", description: "Posts the age verification panel where new members start the verification process." },
  { command: "/verify-word", description: "Issues a unique verification word and countdown timer to a member being verified (staff only)." },
  { command: "/verify-approve", description: "Approves a member's verification, automatically granting the base verified role and gender tag role (staff only)." },
  { command: "/verify-deny", description: "Denies a member's verification attempt (staff only)." },
  { command: "/staff-reply", description: "Sends an anonymized staff reply inside an open ticket, hiding the individual staff member's identity." },
  { command: "/setup-roles", description: "Configures which staff roles have access to which ticket types (Ticket Staff, Owner, Co-Owner, Partnership Manager, ID Verified Staff)." },
  { command: "/setup-verified-tags", description: "Configures the base and gender-specific verification tag roles granted on approval." },
  { command: "/setup-categories", description: "Sets which Discord category each ticket type lands in when opened." },
  { command: "/setup-welcome-channel", description: "Sets the channel where verification welcome messages are posted." },
  { command: "/setup-welcome-message", description: "Sets the custom message template used to welcome newly verified members." },
  { command: "/add-server", description: "Adds a new server to the bot's active rollout (bot owner only)." },
  { command: "/invite", description: "Generates an invite link for the bot to be added to a new server (bot owner only)." },
];
---
<Layout title="Midnight Tickets">
  <section class="section">
    <span class="badge badge-live">Live</span>
    <h2>Midnight Tickets</h2>
  </section>

  <BotTabs summary={summary} details={details} commands={commands} />

  <section class="section">
    <a href="/bots" class="back-link">&larr; Back to Bots</a>
  </section>
</Layout>
<style>
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  .badge-live {
    background-color: #22C55E;
    color: #08130C;
  }
  .badge-planned {
    background-color: #2A2145;
    color: #B8AED0;
  }
  .back-link {
    color: #8A5CF6;
    font-weight: 600;
    text-decoration: none;
  }
  .back-link:hover {
    color: #C4B5FD;
  }
</style>