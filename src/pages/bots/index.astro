---
import Layout from '../../layouts/Layout.astro';
import { getUser, isStaff } from '../../lib/session.js';
import { fetchFromBot } from '../../lib/bot-api.js';
import { BOT_API_HOSTS } from '../../data/bot-hosts.js';
import OverviewView from '../../components/bots/OverviewView.astro';
import ModulesView from '../../components/bots/ModulesView.astro';
import CommandsView from '../../components/bots/CommandsView.astro';
import ServerListingView from '../../components/bots/ServerListingView.astro';
import BotLogsView from '../../components/bots/BotLogsView.astro';
import ActionLogsView from '../../components/bots/ActionLogsView.astro';

const TICKETS_API = BOT_API_HOSTS['Midnight Tickets'];
const COUNCIL_API = BOT_API_HOSTS['Midnight Council'];

const user = getUser(Astro);
const staff = isStaff(user);

const selectedGuildId = Astro.url.searchParams.get('server') || 'all';
const configSaved = Astro.url.searchParams.get('saved') === 'true';
const selectedCouncilGuildId = Astro.url.searchParams.get('councilServer') || 'all';
const councilStaffSaved = Astro.url.searchParams.get('councilSaved') === 'true';

let ticketServers = [];
let ticketGuildOptions = null;
let selectedTicketConfig = null;

let councilServers = [];
let councilNetworkStaff = [];
let councilServerStaff = [];
let councilHealth = null;
let councilAvailable = false;

if (staff) {
  const serversData = await fetchFromBot(TICKETS_API, '/api/servers');
  ticketServers = serversData?.servers || [];

  if (selectedGuildId !== 'all') {
    const botConfigData = await fetchFromBot(TICKETS_API, '/api/bot-config');
    const allConfigs = botConfigData?.configs || [];
    selectedTicketConfig = allConfigs.find((c) => c.guildId === selectedGuildId) || null;
    ticketGuildOptions = await fetchFromBot(TICKETS_API, `/api/guild-options?guildId=${selectedGuildId}`);
  }

  const councilServersData = await fetchFromBot(COUNCIL_API, '/api/servers');
  councilServers = councilServersData?.servers || [];
  councilAvailable = councilServersData !== null;

  const councilNetworkData = await fetchFromBot(COUNCIL_API, '/api/staff?scope=network');
  councilNetworkStaff = councilNetworkData?.staff || [];

  if (selectedCouncilGuildId !== 'all') {
    const councilServerData = await fetchFromBot(COUNCIL_API, `/api/staff?scope=server&guildId=${selectedCouncilGuildId}`);
    councilServerStaff = councilServerData?.staff || [];
  }

  councilHealth = await fetchFromBot(COUNCIL_API, '/api/health');
}
---

<Layout title="Bots">
  <div class="dashboard-wrapper">

    <aside class="sidebar">
      <div class="sidebar-header"><h3>Bot Dashboard</h3></div>
      <nav>
        <div class="nav-item active" data-view="dashboard">Overview</div>
        {staff && <div class="nav-item" data-view="modules">Modules</div>}
        <div class="nav-item" data-view="commands">Commands</div>
        <div class="nav-item" data-view="servers">Server Listing</div>
        {staff && <div class="nav-item" data-view="botlogs">Bot Logs</div>}
        {staff && <div class="nav-item" data-view="actionlogs">Action Logs</div>}
      </nav>
    </aside>

    <main class="main-content">
      <div class="page-banner"></div>

      <div class="overview-container">
        <OverviewView />

        {staff && (
          <ModulesView
            selectedGuildId={selectedGuildId}
            configSaved={configSaved}
            ticketServers={ticketServers}
            ticketGuildOptions={ticketGuildOptions}
            selectedTicketConfig={selectedTicketConfig}
            selectedCouncilGuildId={selectedCouncilGuildId}
            councilStaffSaved={councilStaffSaved}
            councilServers={councilServers}
            councilNetworkStaff={councilNetworkStaff}
            councilServerStaff={councilServerStaff}
            councilAvailable={councilAvailable}
          />
        )}

        <CommandsView />
        <ServerListingView />
        {staff && <BotLogsView councilHealth={councilHealth} />}
        {staff && <ActionLogsView />}
      </div>
    </main>
  </div>

  <script is:inline>
    const navItems = document.querySelectorAll('.nav-item');
    const views = {
      dashboard: document.getElementById('view-dashboard'),
      modules: document.getElementById('view-modules'),
      commands: document.getElementById('view-commands'),
      servers: document.getElementById('view-servers'),
      botlogs: document.getElementById('view-botlogs'),
      actionlogs: document.getElementById('view-actionlogs'),
    };

    function showView(name) {
      navItems.forEach((nav) => nav.classList.toggle('active', nav.getAttribute('data-view') === name));
      Object.entries(views).forEach(([key, el]) => { if (el) el.style.display = key === name ? 'block' : 'none'; });
    }

    navItems.forEach((item) => {
      item.addEventListener('click', () => showView(item.getAttribute('data-view')));
    });

    function openBotSubPage(name) {
      document.getElementById('bot-selection-grid').style.display = 'none';
      document.getElementById('bot-sub-page').style.display = 'block';
      document.getElementById('sub-page-title').innerText = 'Midnight ' + name;

      const isCouncil = name === 'Council';
      document.getElementById('council-live-status').style.display = isCouncil ? 'block' : 'none';
      document.querySelector('.sub-tabs').style.display = isCouncil ? 'none' : 'flex';

      ['logs-table', 'logs-health', 'logs-latency', 'logs-errors'].forEach((tabId) => {
        document.getElementById(tabId).style.display = (!isCouncil && tabId === 'logs-table') ? 'block' : 'none';
      });
      document.querySelectorAll('.tab-btn').forEach((b, i) => b.classList.toggle('active', i === 0));
    }

    function openModuleSubPage(name) {
      document.getElementById('module-selection-grid').style.display = 'none';
      document.querySelectorAll('.module-sub-page').forEach((el) => {
        el.style.display = el.getAttribute('data-bot') === name ? 'block' : 'none';
      });
    }

    function backToModuleGrid() {
      document.getElementById('module-selection-grid').style.display = 'grid';
      document.querySelectorAll('.module-sub-page').forEach((el) => { el.style.display = 'none'; });
    }

    function showCommandBot(name) {
      document.querySelectorAll('.command-group').forEach((el) => {
        el.style.display = el.getAttribute('data-bot') === name ? 'block' : 'none';
      });
    }

    function backToOverview() {
      document.getElementById('bot-selection-grid').style.display = 'grid';
      document.getElementById('bot-sub-page').style.display = 'none';
    }

    function showSubTab(id, btn) {
      ['logs-table', 'logs-health', 'logs-latency', 'logs-errors'].forEach((tabId) => {
        document.getElementById(tabId).style.display = 'none';
      });
      document.getElementById(id).style.display = 'block';
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
    }

    const params = new URLSearchParams(window.location.search);
    if (params.get('view') === 'modules' && views.modules) {
      showView('modules');
      const botParam = params.get('bot');
      if (botParam) openModuleSubPage(botParam);
    }
  </script>
</Layout>

<style>
  .dashboard-wrapper { display: flex; background: #0F0B1E; color: #F0EDF7; }
  .sidebar {
    width: 220px;
    flex-shrink: 0;
    background: #0F0B1E;
    border-right: 1px solid #2A2145;
    align-self: flex-start;
    position: sticky;
    top: 0;
    max-height: 100vh;
    overflow-y: auto;
  }
  .sidebar-header { padding: 1rem 1.25rem; border-bottom: 1px solid #2A2145; }
  .sidebar-header h3 { font-size: 1.05rem; margin: 0; }
  .nav-item { padding: 0.65rem 1.25rem; color: #B8AED0; cursor: pointer; font-size: 0.85rem; }
  .nav-item.active { color: #8A5CF6; border-left: 2px solid #8A5CF6; background: #1A1430; }
  .main-content { flex: 1; min-width: 0; padding-bottom: 3rem; }

  .page-banner {
    width: 100%;
    height: 250px;
    background-image: url('/banners/bots.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .overview-container { padding: 1rem 1.25rem; margin-top: 0; font-size: 0.82rem; }
  .overview-container h3 { font-size: 0.95rem; }
</style>
