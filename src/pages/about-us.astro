---
import Layout from '../layouts/Layout.astro';

const departments = [
  {
    name: "Leadership",
    members: [
      { name: "Staff Member", role: "Owner", bio: "Placeholder bio." },
      { name: "Staff Member", role: "Co-Owner", bio: "Placeholder bio." },
    ]
  },
  {
    name: "Moderation",
    members: [
      { name: "Staff Member", role: "Admin", bio: "Placeholder bio." },
      { name: "Staff Member", role: "Mod", bio: "Placeholder bio." },
      { name: "Staff Member", role: "Helper", bio: "Placeholder bio." },
    ]
  },
  {
    name: "Partnerships",
    members: [
      { name: "Staff Member", role: "Partnership Manager", bio: "Placeholder bio." },
    ]
  },
  {
    name: "Events",
    members: [
      { name: "Staff Member", role: "Event Manager", bio: "Placeholder bio." },
    ]
  },
  {
    name: "Health Department",
    members: [
      { name: "Staff Member", role: "Health Department", bio: "Placeholder bio." },
    ]
  },
];

const serverRules = [
  { name: "Den of Desire", slug: "server-1", summary: "Placeholder rule summary." },
  { name: "Underground Gamer Lounge", slug: "server-2", summary: "Placeholder rule summary." },
  { name: "Chaos Midnight House", slug: "server-3", summary: "Placeholder rule summary." },
  { name: "Smutty Library Cafe", slug: "server-4", summary: "Placeholder rule summary." },
  { name: "Velvet Cosy Collars", slug: "server-5", summary: "Placeholder rule summary." },
  { name: "Advertising Lounge", slug: "server-6", summary: "Placeholder rule summary." },
  { name: "Server 7", slug: "server-7", summary: "Placeholder rule summary." },
];
---
<Layout title="About Us">
  <section class="section">
    <h2>About Us</h2>
    <p class="intro">Placeholder description of the Midnight Network, its mission, and its community.</p>
  </section>

  <section class="section">
    <h3>Our Staff</h3>
    {departments.map(dept => (
      <div class="department-block">
        <h4>{dept.name}</h4>
        <div class="card-grid">
          {dept.members.map(member => (
            <div class="card">
              <h4 class="member-name">{member.name}</h4>
              <p class="role">{member.role}</p>
              <p>{member.bio}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <section class="section">
    <h3>Server Rules</h3>
    <p class="intro">Each server has its own full rule set. Quick summaries below, with links to the complete rules.</p>
    <div class="card-grid">
      {serverRules.map(server => (
        <a href={`/servers/${server.slug}`} class="card">
          <h4>{server.name}</h4>
          <p>{server.summary}</p>
          <span class="view-rules">View full rules &rarr;</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
<style>
  .intro {
    max-width: 600px;
    margin: 1rem auto 0;
    color: #B8AED0;
  }
  h3 {
    font-size: 1.5rem;
    color: #C4B5FD;
    text-align: center;
    margin-top: 2.5rem;
  }
  .department-block {
    max-width: 1000px;
    margin: 0 auto 2rem;
    padding: 0 1rem;
  }
  .department-block h4:first-child {
    text-align: center;
    color: #8A5CF6;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin: 0 auto;
  }
  .card {
    background-color: #1A1430;
    border: 1px solid #2A2145;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: #F0EDF7;
    transition: transform 0.2s, border-color 0.2s;
  }
  a.card:hover {
    transform: translateY(-4px);
    border-color: #8A5CF6;
  }
  .member-name {
    color: #C4B5FD;
    margin: 0 0 0.25rem;
  }
  .card .role {
    color: #8A5CF6;
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .card p {
    margin: 0;
    font-size: 0.9rem;
    color: #B8AED0;
  }
  .view-rules {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #8A5CF6;
    font-weight: 600;
  }
</style>