---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { requireAuth } from '../../lib/session.js';

const { redirect } = requireAuth(Astro);
if (redirect) return redirect;
---

<Layout title="Consent Settings">
  <div class="dashboard-wrapper">
    <Sidebar />
    <main class="content">
      <h1>Consent Settings</h1>
      <p class="placeholder-note">Coming soon — set your DM, friend request, and voice call consent status here once Midnight Bonds is live.</p>
    </main>
  </div>
</Layout>

<style>
  .dashboard-wrapper { display: flex; background: #0F0B1E; color: white; }
  .content { padding: 1.5rem; flex: 1; min-width: 0; }
  .placeholder-note { margin: 0.5rem 0 0; font-size: 0.9rem; color: #8A7FA8; line-height: 1.5; max-width: 500px; }
</style>
